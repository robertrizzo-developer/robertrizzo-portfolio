# --- Local MySQL (default ./mvnw without Docker profile) ---
DB_URL=jdbc:mysql://localhost:3306/jarnviljadb
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_DIALECT=org.hibernate.dialect.MySQL8Dialect
DDL_AUTO=update

# --- Docker Compose (PostgreSQL + Spring) ---
# Copy this file to `.env` and adjust. Compose reads these automatically.
POSTGRES_DB=jarnviljadb
POSTGRES_USER=jarnvilja
POSTGRES_PASSWORD=jarnvilja
POSTGRES_PORT=5432
APP_PORT=8080

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
