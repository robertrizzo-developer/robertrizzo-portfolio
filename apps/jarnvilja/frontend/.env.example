# Base URL for API calls. Leave empty when using Vite dev server proxy (same origin).
VITE_API_BASE_URL=

# mock = in-memory API (no Java), demo/demo123. live = Spring Boot backend.
# Portfolio embed uses mock (.env.development / .env.production set to mock).
VITE_API_MODE=mock

# Target for Vite proxy (backend origin during npm run dev).
VITE_PROXY_TARGET=http://localhost:8080
