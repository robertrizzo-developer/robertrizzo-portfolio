{
  "name": "portfolio-monorepo",
  "private": true,
  "workspaces": ["apps/portfolio", "apps/jarnvilja/frontend"],
  "scripts": {
    "dev": "concurrently -n portfolio,jarnvilja-fe,jarnvilja-be -c blue,cyan,magenta \"npm run dev:portfolio\" \"npm run dev:jarnvilja-frontend\" \"npm run dev:jarnvilja-backend\"",
    "dev:portfolio": "npm run dev -w apps/portfolio",
    "dev:jarnvilja-frontend": "npm run dev -w apps/jarnvilja/frontend",
    "dev:jarnvilja-backend": "cd apps/jarnvilja && ./mvnw spring-boot:run -Dspring-boot.run.profiles=demo",
    "dev:jarnvilja": "npm run dev:jarnvilja-frontend",
    "build": "npm run build:portfolio",
    "build:portfolio": "npm run build -w apps/portfolio",
    "build:jarnvilja": "npm run build -w apps/jarnvilja/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
