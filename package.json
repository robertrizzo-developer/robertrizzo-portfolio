{
  "name": "portfolio-monorepo",
  "private": true,
  "workspaces": [
    "apps/portfolio",
    "apps/jarnvilja/frontend",
    "apps/refactoring-visualizer"
  ],
  "scripts": {
    "dev": "concurrently -n portfolio,jarnvilja-fe,jarnvilja-be,refactor-viz -c blue,cyan,magenta,green \"npm run dev:portfolio\" \"npm run dev:jarnvilja-frontend\" \"npm run dev:jarnvilja-backend\" \"npm run dev:refactoring-visualizer\"",
    "dev:portfolio": "npm run dev -w apps/portfolio",
    "dev:jarnvilja-frontend": "npm run dev -w apps/jarnvilja/frontend",
    "dev:jarnvilja-backend": "cd apps/jarnvilja && ./mvnw spring-boot:run -Dspring-boot.run.profiles=demo",
    "dev:jarnvilja": "npm run dev:jarnvilja-frontend",
    "dev:refactoring-visualizer": "npm run dev -w apps/refactoring-visualizer",
    "build": "npm run build:portfolio",
    "build:portfolio": "npm run build -w apps/portfolio",
    "build:jarnvilja": "npm run build -w apps/jarnvilja/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "framer-motion": "^12.38.0"
  }
}
